generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma-master"
}

datasource db {
  provider = "sqlite"
}

model Tenant {
  id             String   @id @default(cuid())
  name           String
  slug           String   @unique
  logoUrl        String?
  primaryColor   String   @default("#f97316")
  secondaryColor String   @default("#ea580c")
  adminName      String
  adminEmail     String
  tursoDbUrl     String
  tursoAuthToken String
  isActive       Boolean  @default(true)
  enablePlans    Boolean  @default(true)
  enableTimer    Boolean  @default(true)
  createdAt      DateTime @default(now())
}

model SuperAdmin {
  id           String   @id @default(cuid())
  email        String   @unique
  passwordHash String
  createdAt    DateTime @default(now())
}
