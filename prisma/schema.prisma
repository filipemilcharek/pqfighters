generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "sqlite"
}

model User {
  id                 String    @id @default(cuid())
  name               String
  email              String    @unique
  passwordHash       String
  role               String    @default("STUDENT") // ADMIN | STUDENT
  status             String    @default("PENDING") // PENDING | APPROVED
  studentType        String    @default("ESSENCIAL") // ESSENCIAL | PRO | PREMIUM
  belt               String    @default("BRANCA")
  degrees            Int       @default(0)
  initialCheckins    Int       @default(0)
  monthlyCredits     Int       @default(0)
  modalities         String    @default("GRAPPLING") // GRAPPLING, MMA, ou GRAPPLING,MMA
  isKids             Boolean   @default(false)
  photoUrl           String?
  monthlyDueDay      Int?
  lastPaymentDate    DateTime?
  lastGraduationDate DateTime?
  lastBeltChangeDate DateTime?
  createdAt          DateTime  @default(now())

  bookings          Booking[]
  privateSlots      PrivateSlot[]
  createdEvents     Event[]
  createdNotifs     Notification[]
  notificationReads NotificationRead[]
  rescheduleLogs    RescheduleLog[]
  graduationLogs      GraduationLog[]
  planUpgradeRequests PlanUpgradeRequest[]
}

model PrivateSlot {
  id          String  @id @default(cuid())
  dayOfWeek   Int // 0=domingo, 1=segunda...6=sabado
  startTime   String // "HH:mm"
  endTime     String // "HH:mm"
  isAvailable Boolean @default(true)
  userId      String?

  user              User?            @relation(fields: [userId], references: [id], onDelete: Cascade)
  bookings          Booking[]
  rescheduleLogs    RescheduleLog[] @relation("originalSlot")
  rescheduleNewLogs RescheduleLog[] @relation("newSlot")
}

model GroupClass {
  id        String @id @default(cuid())
  name      String
  dayOfWeek Int
  startTime String
  endTime   String
  capacity  Int
  isKids    Boolean @default(false)

  bookings Booking[]
}

model Booking {
  id            String   @id @default(cuid())
  userId        String
  type          String // PRIVATE | GROUP
  privateSlotId String?
  groupClassId  String?
  date          String // "YYYY-MM-DD"
  status        String   @default("CONFIRMED")
  checkedIn     Boolean  @default(false)
  checkinStatus String?  // PRESENTE | CANCELADO | AUSENTE
  createdAt     DateTime @default(now())

  user        User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  privateSlot PrivateSlot? @relation(fields: [privateSlotId], references: [id], onDelete: SetNull)
  groupClass  GroupClass?  @relation(fields: [groupClassId], references: [id], onDelete: SetNull)
}

model Event {
  id          String   @id @default(cuid())
  title       String
  description String   @default("")
  date        String
  createdById String
  createdAt   DateTime @default(now())

  createdBy User @relation(fields: [createdById], references: [id], onDelete: Cascade)
}

model Notification {
  id          String   @id @default(cuid())
  title       String
  message     String
  createdById String
  createdAt   DateTime @default(now())

  createdBy User               @relation(fields: [createdById], references: [id], onDelete: Cascade)
  reads     NotificationRead[]
}

model BeltRequirement {
  id             String @id @default(cuid())
  belt           String @unique // AZUL, ROXA, MARROM, PRETA
  requiredClasses Int
}

model DegreeRequirement {
  id              String @id @default(cuid())
  belt            String
  degree          Int
  requiredClasses Int

  @@unique([belt, degree])
}

model NotificationRead {
  id             String   @id @default(cuid())
  notificationId String
  userId         String
  createdAt      DateTime @default(now())

  notification Notification @relation(fields: [notificationId], references: [id], onDelete: Cascade)
  user         User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([notificationId, userId])
}

model PlanUpgradeRequest {
  id          String   @id @default(cuid())
  userId      String
  plan        String   // Essencial | Pro | Premium | Kids
  frequency   String   // mensal, trimestral, semestral, anual, etc.
  details     String?  // frequência semanal ou pacote (ex: "2x_semana", "pacote_5_aulas")
  price       String   // valor formatado
  status      String   @default("PENDING") // PENDING | APPROVED | REJECTED
  readByAdmin Boolean  @default(false)
  createdAt   DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model GraduationLog {
  id        String   @id @default(cuid())
  userId    String
  belt      String
  degrees   Int
  type      String   // BELT | DEGREE
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model RescheduleLog {
  id               String       @id @default(cuid())
  type             String       @default("RESCHEDULE") // RESCHEDULE | BOOKING
  userId           String
  privateSlotId    String
  date             String
  newPrivateSlotId String?
  newDate          String?
  readByAdmin      Boolean      @default(false)
  createdAt        DateTime     @default(now())
  user             User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  privateSlot      PrivateSlot  @relation("originalSlot", fields: [privateSlotId], references: [id], onDelete: Cascade)
  newPrivateSlot   PrivateSlot? @relation("newSlot", fields: [newPrivateSlotId], references: [id], onDelete: Cascade)
  @@unique([privateSlotId, date, type])
}
