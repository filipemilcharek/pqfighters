generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "sqlite"
}

model User {
  id                 String    @id @default(cuid())
  name               String
  email              String    @unique
  passwordHash       String
  role               String    @default("STUDENT") // ADMIN | STUDENT
  status             String    @default("PENDING") // PENDING | APPROVED
  isOwner            Boolean   @default(false)
  studentType        String    @default("COLETIVA") // COLETIVA | PARTICULAR
  planId             String?
  belt               String    @default("BRANCA")
  degrees            Int       @default(0)
  initialCheckins    Int       @default(0)
  monthlyCredits     Int       @default(0)
  modalities         String    @default("GRAPPLING") // GRAPPLING, MMA, ou GRAPPLING,MMA
  isKids             Boolean   @default(false)
  photoUrl           String?
  monthlyDueDay      Int?
  lastPaymentDate    DateTime?
  lastGraduationDate DateTime?
  lastBeltChangeDate DateTime?
  createdAt          DateTime  @default(now())

  bookings          Booking[]
  privateSlots      PrivateSlot[]
  instructorClasses GroupClass[]   @relation("instructorClasses")
  instructorSlots   PrivateSlot[]  @relation("instructorSlots")
  createdEvents     Event[]
  createdNotifs     Notification[]
  notificationReads NotificationRead[]
  rescheduleLogs    RescheduleLog[]
  graduationLogs      GraduationLog[]
  planUpgradeRequests PlanUpgradeRequest[]
  classEnrollments    GroupClassEnrollment[]
}

model PrivateSlot {
  id           String  @id @default(cuid())
  dayOfWeek    Int // 0=domingo, 1=segunda...6=sabado
  startTime    String // "HH:mm"
  endTime      String // "HH:mm"
  isAvailable  Boolean @default(true)
  userId       String?
  instructorId String?

  user              User?            @relation(fields: [userId], references: [id], onDelete: Cascade)
  instructor        User?            @relation("instructorSlots", fields: [instructorId], references: [id], onDelete: SetNull)
  bookings          Booking[]
  rescheduleLogs    RescheduleLog[] @relation("originalSlot")
  rescheduleNewLogs RescheduleLog[] @relation("newSlot")
}

model GroupClass {
  id           String  @id @default(cuid())
  name         String
  dayOfWeek    Int
  startTime    String
  endTime      String
  capacity     Int
  isKids       Boolean @default(false)
  classType    String  @default("GROUP")
  fixedRoster  Boolean @default(false)
  instructorId String?

  instructor  User?                  @relation("instructorClasses", fields: [instructorId], references: [id], onDelete: SetNull)
  bookings    Booking[]
  enrollments GroupClassEnrollment[]
}

model GroupClassEnrollment {
  id           String @id @default(cuid())
  groupClassId String
  userId       String

  groupClass GroupClass @relation(fields: [groupClassId], references: [id], onDelete: Cascade)
  user       User       @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([groupClassId, userId])
}

model Booking {
  id            String   @id @default(cuid())
  userId        String
  type          String // PRIVATE | GROUP
  privateSlotId String?
  groupClassId  String?
  date          String // "YYYY-MM-DD"
  status        String   @default("CONFIRMED")
  checkedIn     Boolean  @default(false)
  checkinStatus String?  // PRESENTE | CANCELADO | AUSENTE
  createdAt     DateTime @default(now())

  user        User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  privateSlot PrivateSlot? @relation(fields: [privateSlotId], references: [id], onDelete: SetNull)
  groupClass  GroupClass?  @relation(fields: [groupClassId], references: [id], onDelete: SetNull)
}

model Event {
  id          String   @id @default(cuid())
  title       String
  description String   @default("")
  date        String
  createdById String
  createdAt   DateTime @default(now())

  createdBy User @relation(fields: [createdById], references: [id], onDelete: Cascade)
}

model Notification {
  id          String   @id @default(cuid())
  title       String
  message     String
  createdById String
  createdAt   DateTime @default(now())

  createdBy User               @relation(fields: [createdById], references: [id], onDelete: Cascade)
  reads     NotificationRead[]
}

model BeltRequirement {
  id             String @id @default(cuid())
  belt           String @unique // AZUL, ROXA, MARROM, PRETA
  requiredClasses Int
}

model DegreeRequirement {
  id              String @id @default(cuid())
  belt            String
  degree          Int
  requiredClasses Int

  @@unique([belt, degree])
}

model NotificationRead {
  id             String   @id @default(cuid())
  notificationId String
  userId         String
  createdAt      DateTime @default(now())

  notification Notification @relation(fields: [notificationId], references: [id], onDelete: Cascade)
  user         User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([notificationId, userId])
}

model PlanUpgradeRequest {
  id          String   @id @default(cuid())
  userId      String
  planId      String?
  plan        String   // nome do plano solicitado
  frequency   String   // mensal, trimestral, semestral, anual, etc.
  details     String?
  price       String   // valor formatado
  status      String   @default("PENDING") // PENDING | APPROVED | REJECTED
  readByAdmin Boolean  @default(false)
  createdAt   DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model GraduationLog {
  id        String   @id @default(cuid())
  userId    String
  belt      String
  degrees   Int
  type      String   // BELT | DEGREE
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Plan {
  id             String   @id @default(cuid())
  name           String
  description    String   @default("")
  price          String
  frequency      String
  planType       String   // COLETIVA | PARTICULAR
  monthlyCredits Int      @default(0)
  isActive       Boolean  @default(true)
  createdAt      DateTime @default(now())
}

model RescheduleLog {
  id               String       @id @default(cuid())
  type             String       @default("RESCHEDULE") // RESCHEDULE | BOOKING
  userId           String
  privateSlotId    String
  date             String
  newPrivateSlotId String?
  newDate          String?
  readByAdmin      Boolean      @default(false)
  createdAt        DateTime     @default(now())
  user             User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  privateSlot      PrivateSlot  @relation("originalSlot", fields: [privateSlotId], references: [id], onDelete: Cascade)
  newPrivateSlot   PrivateSlot? @relation("newSlot", fields: [newPrivateSlotId], references: [id], onDelete: Cascade)
  @@unique([privateSlotId, date, type])
}
