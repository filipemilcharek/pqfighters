generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "sqlite"
}

model User {
  id                 String    @id @default(cuid())
  name               String
  email              String    @unique
  passwordHash       String
  role               String    @default("STUDENT") // ADMIN | STUDENT
  studentType        String    @default("COLETIVA") // PARTICULAR | COLETIVA
  belt               String    @default("BRANCA")
  degrees            Int       @default(0)
  initialCheckins    Int       @default(0)
  photoUrl           String?
  monthlyDueDay      Int?
  lastPaymentDate    DateTime?
  lastGraduationDate DateTime?
  createdAt          DateTime  @default(now())

  bookings          Booking[]
  createdEvents     Event[]
  createdNotifs     Notification[]
  notificationReads NotificationRead[]
}

model PrivateSlot {
  id          String  @id @default(cuid())
  dayOfWeek   Int // 0=domingo, 1=segunda...6=sabado
  startTime   String // "HH:mm"
  endTime     String // "HH:mm"
  isAvailable Boolean @default(true)

  bookings Booking[]
}

model GroupClass {
  id        String @id @default(cuid())
  name      String
  dayOfWeek Int
  startTime String
  endTime   String
  capacity  Int

  bookings Booking[]
}

model Booking {
  id            String   @id @default(cuid())
  userId        String
  type          String // PRIVATE | GROUP
  privateSlotId String?
  groupClassId  String?
  date          String // "YYYY-MM-DD"
  status        String   @default("CONFIRMED")
  checkedIn     Boolean  @default(false)
  checkinStatus String?  // PRESENTE | CANCELADO | AUSENTE
  createdAt     DateTime @default(now())

  user        User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  privateSlot PrivateSlot? @relation(fields: [privateSlotId], references: [id], onDelete: SetNull)
  groupClass  GroupClass?  @relation(fields: [groupClassId], references: [id], onDelete: SetNull)

  @@unique([privateSlotId, date])
}

model Event {
  id          String   @id @default(cuid())
  title       String
  description String   @default("")
  date        String
  createdById String
  createdAt   DateTime @default(now())

  createdBy User @relation(fields: [createdById], references: [id], onDelete: Cascade)
}

model Notification {
  id          String   @id @default(cuid())
  title       String
  message     String
  createdById String
  createdAt   DateTime @default(now())

  createdBy User               @relation(fields: [createdById], references: [id], onDelete: Cascade)
  reads     NotificationRead[]
}

model BeltRequirement {
  id             String @id @default(cuid())
  belt           String @unique // AZUL, ROXA, MARROM, PRETA
  requiredClasses Int
}

model DegreeRequirement {
  id              String @id @default(cuid())
  belt            String
  degree          Int
  requiredClasses Int

  @@unique([belt, degree])
}

model NotificationRead {
  id             String   @id @default(cuid())
  notificationId String
  userId         String
  createdAt      DateTime @default(now())

  notification Notification @relation(fields: [notificationId], references: [id], onDelete: Cascade)
  user         User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([notificationId, userId])
}
